# HireOps Backend Context

# 1. Database & Caching
# For Neon DB (managed PostgreSQL): asyncpg handles SSL automatically, no ?ssl= parameter needed
# Example: postgresql+asyncpg://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb
DATABASE_URL=postgresql+asyncpg://YOUR_NEON_CONNECTION_STRING
REDIS_URL=redis://redis:6379/0

# 2. Celery Worker QUEUE
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# 3. Security (JWT)
SECRET_KEY=generate_a_secure_random_string_here_like_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 4. Third-Party AI / LLM APIs (Agentic Capabilities)
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
# HUGGINGFACE_API_KEY=hf_your_key_here # if using local models hosted on HF

# 5. Third-Party Payment (Stripe)
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# 6. Email Delivery (e.g. Resend, SendGrid)
RESEND_API_KEY=re_your_resend_key_here

# 7. Video / Real-time Services (e.g., Daily.co, LiveKit, or Twilio)
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
LIVEKIT_URL=wss://your-project.livekit.cloud
